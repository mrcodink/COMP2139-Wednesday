@* Indicate *@

@model List<Project>

@{
    ViewBag.Title = "Project Listing";
    Layout = "_Layout";
}

<h2>Project Listing</h2>

@if (Model.Any())
{
    // Iterate over projects
    <table class="table">

        <thead>
        <th>ID</th>
        <th>Name</th>
        <th>Description</th>
        </thead>

        <tbody>
        @foreach(var project in Model)
        {
            <tr>
                <td>@project.ProjectId</td>
                <td>@project.Name</td>
                <td>@project.Description</td>

            </tr>
        }

        </tbody>

    </table>
}
else
{

}
